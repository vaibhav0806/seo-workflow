# Worker mode:
# - oneshot: run one scan and exit
# - oneshot-competitor: compare CreateOS vs competitor sitemaps + opportunities
# - standby: wait for signals only
WORKER_MODE=oneshot

# GSC property identifier.
# Examples:
#   sc-domain:example.com
#   https://www.example.com/
SCAN_PROPERTY=sc-domain:example.com

# GitHub repository in owner/repo format.
SCAN_REPO=owner/repo

# Public sitemap URL that lists URLs to scan.
SCAN_SITEMAP_URL=https://example.com/sitemap.xml

# Google Search Console OAuth access token (user token).
# Usually starts with: ya29.
GSC_ACCESS_TOKEN=

# Dry run mode:
# - true: do not write to GitHub, returns dry-run PR URL
# - false: create/update branch + open a real PR
WORKER_DRY_RUN=true

# Required only when WORKER_DRY_RUN=false.
# GitHub token with repo write + pull request permissions.
GITHUB_TOKEN=

# Optional tuning
SCAN_QPM=600
GSC_LOOKBACK_DAYS=7
GSC_ROW_LIMIT=1000
GSC_HTTP_TIMEOUT_SEC=30
GITHUB_BASE_BRANCH=main
GITHUB_SITEMAP_PATH=public/sitemap.xml
ONESHOT_REPORT_PATH=

# --------------------------------------
# Competitor oneshot mode (optional)
# --------------------------------------
# Required when WORKER_MODE=oneshot-competitor
OUR_SITEMAP_URL=https://createos.sh/sitemap.xml

# Optional competitor-mode tuning
COMPETITOR_WINDOW_DAYS=30
COMPETITOR_HTTP_TIMEOUT_SEC=30
COMPETITOR_REPORT_PATH=competitor-report.json

# Optional AI enrichment for actionables (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2.6
